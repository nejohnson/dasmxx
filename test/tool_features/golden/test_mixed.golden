   dasmz80 -- Zilog Z80 Disassembler --
-----------------------------------------------------------------

;   Processing "../testdata/simple_code.bin" (50 bytes)
;   Disassembly start address: 0x0000
;   String terminator: 0x00

___CL_0001:
    0000:    3E 42          LD       A, #$42
    0002:    C3 10 00       JP       $0010
    0005:    CD 20 00       CALL     ___BDATA_0001
    0008:    00             NOP      
    0009:    00             NOP      
    000A:    00             NOP      


___STRING_0001:
    000B:    DB      'Hello'
    0011:    DB      ''
    0012:    DB      ''
    0013:    DB      '!\10'
    0016:    DB      '\C9\01'

;----------------------------------------------------------------
;        Function: MyProc

MyProc:
    0018:    02             LD       (BC), A
    0019:    03             INC      BC
    001A:    04             INC      B
    001B:    05             DEC      B
    001C:    06 07          LD       B, #$07
    001E:    08             EX       AF, AF'
    001F:    34             INC      (HL)


___BDATA_0001:
    0020:    DB      12, 78, 56, 57, 6F, 72, 6C, 64      .xVWorld
                                      

___WDATA_0001:
    0028:    DW      0021, 0041

___STRING_0002:
    002C:    DB      'B'
    002E:    DB      'C'
    0030:    DB      ''
    0031:    DB      ''
